generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://admin:nimda@db:5432/pizzaro?schema=public"
}


model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MenuSection {
  id       Int      @id @default(autoincrement())
  name     String
  slug     String   @unique
  schema   Json?    
  order    Int?     
  items    MenuItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("menu_sections")
}

model MenuItem {
  id          Int       @id @default(autoincrement())
  sectionId   Int
  name        String
  description String?
  imageUrl    String?
  order       Int?      // порядковый номер в секции
  data        Json?     // хранит варианты, цену, вес, калории и т.д.

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  menuSection MenuSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("menu_items")
}